# ─── Database ────────────────────────────────────────────────────
# Development (MySQL local)
DATABASE_URL=mysql+pymysql://root:@localhost:3306/moneylog

# Production — uncomment and fill before deploy:
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/moneylog

# ─── Security ────────────────────────────────────────────────────
# IMPORTANT: Generate a strong key before production!
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_USE_A_STRONG_RANDOM_KEY_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─── AI (OpenRouter) ─────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-your-key-here
AI_MODEL=deepseek/deepseek-r1:free
AI_SITE_URL=https://moneylog.app
AI_SITE_NAME=MoneyLog